# 数据库连接（必填）
DB_DSN=user:password@tcp(127.0.0.1:3306)/dbname?charset=utf8mb4&parseTime=True&loc=Local

# 查询超时（秒，默认 300）
# QUERY_TIMEOUT=300

# S3 预签名配置（仅在使用 [URL] 元数据时需要）
# 支持 AWS S3、阿里云 OSS、MinIO 等所有 S3 兼容存储
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_REGION=us-west-1
# S3_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com  # 可选，OSS/MinIO 必填
